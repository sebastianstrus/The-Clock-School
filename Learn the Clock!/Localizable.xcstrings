    "Are you sure you want to delete the application cache and close the app?" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sind Sie sicher, dass Sie den Anwendungscache löschen und die App schließen möchten?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to delete the application cache and close the app?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Estás seguro de que quieres borrar el caché y cerrar la aplicación?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir supprimer le cache de l'application et fermer l'application ?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei sicuro di voler eliminare la cache e chiudere l'app?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アプリケーションのキャッシュを削除してアプリを終了してもよろしいですか？"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på at du vil slette app-bufferen og lukke appen?"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Czy na pewno chcesz usunąć pamięć podręczną i zamknąć aplikację?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem certeza de que deseja excluir o cache e fechar o aplicativo?"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Är du säker på att du vill rensa appens cache och stänga av den?"
