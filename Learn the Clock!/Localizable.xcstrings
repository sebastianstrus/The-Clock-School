    "Pick Easy, Medium, or Hard. Switch between 12 or 24-hour clocks. You're in control." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wähle Einfach, Mittel oder Schwer. Wechsle zwischen 12 oder 24 Stunden. Du hast die Kontrolle."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pick Easy, Medium, or Hard. Switch between 12 or 24-hour clocks. You're in control."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige Fácil, Medio o Difícil. Cambia entre 12 o 24 horas. Tú tienes el control."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Facile, Moyen ou Difficile. Alternez entre 12h et 24h. C'est vous qui décidez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scegli Facile, Medio o Difficile. Passa dal formato 12 a quello 24 ore. Decidi tu."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「かんたん」「ふつう」「むずかしい」から選択。12時間制と24時間制も切り替え可能。すべてはあなた次第。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Velg Lett, Middels eller Vanskelig. Bytt mellom 12- og 24-timers klokke. Du bestemmer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wybierz Łatwy, Średni lub Trudny. Przełączaj między 12 a 24 godzinami. Ty tu rządzisz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolha Fácil, Médio ou Difícil. Alterne entre 12 ou 24 horas. Você está no controle."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Välj Lätt, Medel eller Svår. Växla mellan 12- och 24-timmarsvisning. Du bestämmer."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Обирайте Легкий, Середній або Складний рівень. Перемикайтеся між 12 та 24 годинами."
          }
        }
      }
    },
