    "Complete all exercises to earn your score. Challenge yourself and improve every day!" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schließe alle Übungen ab, um deine Punktzahl zu erhalten. Fordere dich selbst heraus!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
